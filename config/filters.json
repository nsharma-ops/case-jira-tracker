{
  "salesforce": {
    "case_days_back": 365,
    "limit": 2000,
    "jira_link_fields": [
      "Jira_Ticket_Link__c",
      "Jira_Ticket__c",
      "Jira_Ticket_Number__c"
    ],
    "jira_status_field": "Jira_Ticket_Status__c",
    "lightning_base": "https://tractionrec.lightning.force.com"
  },
  "jira": {
    "domain": "tractionrec.atlassian.net",
    "batch_size": 50,
    "cases_field": "customfield_13822",
    "case_accounts_field": "customfield_13823",
    "salesforce_record_field": "customfield_13250"
  },
  "jira_scan": {
    "jql": "project = TOD029 AND issuetype NOT IN (\"Release Management\", Epic) AND updated >= -365d ORDER BY updated DESC",
    "page_size": 100,
    "max_issues": 500
  },
  "jira_closed_statuses": [
    "Done",
    "Closed",
    "Resolved",
    "Released",
    "Complete",
    "Cancelled",
    "Won't Do",
    "Won't Fix"
  ],
  "jira_open_statuses": [
    "To Do",
    "Open",
    "In Progress",
    "In Development",
    "In Review",
    "Backlog",
    "Selected for Development",
    "Ready for QA",
    "In QA",
    "Blocked"
  ]
}
