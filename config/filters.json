{
  "salesforce": {
    "case_days_back": 365,
    "limit": 2000,
    "jira_link_fields": [
      "Jira_Ticket_Link__c",
      "Jira_Ticket__c",
      "Jira_Ticket_Number__c"
    ],
    "jira_status_field": "Jira_Ticket_Status__c",
    "lightning_base": "https://tractionrec.lightning.force.com"
  },
  "jira": {
    "domain": "tractionrec.atlassian.net",
    "batch_size": 50
  },
  "jira_bootstrap": {
    "enabled": true,
    "jql": "project = TOD029 AND updated >= -180d ORDER BY updated DESC",
    "max_results": 75
  },
  "jira_closed_statuses": [
    "Done",
    "Closed",
    "Resolved",
    "Released",
    "Complete",
    "Cancelled",
    "Won't Do",
    "Won't Fix"
  ],
  "jira_open_statuses": [
    "To Do",
    "Open",
    "In Progress",
    "In Development",
    "In Review",
    "Backlog",
    "Selected for Development",
    "Ready for QA",
    "In QA",
    "Blocked"
  ]
}
